.idea/
.vscode/
.claude/
.codex/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# These live inside a workspace, not in this repo.
# If you are committing a workspace, you may want to keep agents/
# but exclude the generated context files within each agent dir.
**/agents/*/CLAUDE.md
**/agents/*/.multigent/
**/agents/*/.claude/skills/
**/agents/*/AGENTS.md
**/agents/*/context.md
# Keep the agent metadata so sync can detect changes
!**/agents/*/.multigent/agent.yaml

.npmrc
.env
.env.*
!.env.example

/multigent

# Internal/private planning notes
docs/internal/
